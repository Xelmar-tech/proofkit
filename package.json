{
  "name": "tui-proof-kit",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "check-types": "turbo check-types",
    "check": "oxlint && oxfmt --check",
    "format": "oxfmt --write",
    "prepare": "lefthook install",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build && changeset publish"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@tui-proof-kit/config": "workspace:*",
    "lefthook": "^1.13.6",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.8.12",
    "typescript": "^6",
    "wrangler": "3.90.0"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.0"
    }
  }
}
