{
  "name": "@capxul/tui-test-kit",
  "version": "0.2.0",
  "description": "Drive terminal apps, record sessions, produce evidence packs.",
  "keywords": [
    "asciinema",
    "pty",
    "terminal",
    "testing",
    "tui"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@xterm/headless": "^6.0.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@tui-proof-kit/config": "workspace:*",
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8.5.1",
    "typescript": "^6",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "typescript": "^5 || ^6"
  },
  "engines": {
    "node": ">=22"
  }
}
